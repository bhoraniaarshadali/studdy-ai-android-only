<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            style="@style/Studdy.Toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:title="Exam Paper Generator"
            app:navigationIcon="@drawable/ic_back" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="40dp">

                <!-- Stepper -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tv_step_1_number"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_circle_primary"
                            android:gravity="center"
                            android:text="1"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-bold" />
                        <TextView
                            android:id="@+id/tv_step_1_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Upload PDF"
                            android:textColor="@color/text_primary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="40dp"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="8dp"
                        android:layout_marginTop="-10dp"
                        android:background="@color/divider" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">
                            <TextView
                                android:id="@+id/tv_step_2_number"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_circle_grey"
                                android:gravity="center"
                                android:text="2"
                                android:textColor="@color/text_secondary"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-bold" />
                            <ImageView
                                android:id="@+id/iv_step_2_check"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_circle_success"
                                android:padding="6dp"
                                android:src="@drawable/ic_check"
                                app:tint="@color/white"
                                android:visibility="gone" />
                        </FrameLayout>
                        <TextView
                            android:id="@+id/tv_step_2_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Configure"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="40dp"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="8dp"
                        android:layout_marginTop="-10dp"
                        android:background="@color/divider" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tv_step_3_number"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_circle_grey"
                            android:gravity="center"
                            android:text="3"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-bold" />
                        <TextView
                            android:id="@+id/tv_step_3_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Generate"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Upload Card -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Studdy.Card.Flat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginBottom="20dp"
                    app:strokeColor="@color/divider">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="24dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_pdf_paper" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="Upload Syllabus PDF"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:fontFamily="sans-serif-bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="AI will generate questions strictly from this PDF"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:gravity="center" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_choose_pdf"
                            style="@style/Studdy.Button.Secondary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:text="Choose PDF"
                            android:textAllCaps="false"
                            app:cornerRadius="20dp"
                            android:minHeight="40dp" />

                        <TextView
                            android:id="@+id/tv_pdf_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="No PDF file selected"
                            android:textColor="@color/brand_primary"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:visibility="gone"
                            tools:visibility="visible" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Configuration Card -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Studdy.Card.Flat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_paper_title"
                            style="@style/Studdy.TextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Paper Title">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_paper_title"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textCapWords"
                                android:maxLines="1" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="8dp"
                            android:text="Template"
                            android:textColor="@color/text_primary"
                            android:fontFamily="sans-serif-medium" />

                        <Spinner
                            android:id="@+id/spinner_template"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_spinner" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:layout_marginBottom="12dp"
                            android:text="Overall Difficulty"
                            android:textColor="@color/text_primary"
                            android:fontFamily="sans-serif-medium" />

                        <com.google.android.material.button.MaterialButtonToggleGroup
                            android:id="@+id/toggle_overall_difficulty"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:singleSelection="true"
                            app:selectionRequired="true">
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_diff_easy"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Easy Paper"
                                android:textAllCaps="false" />
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_diff_balanced"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Balanced"
                                android:textAllCaps="false"
                                android:checked="true" />
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_diff_tough"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Tough Paper"
                                android:textAllCaps="false" />
                        </com.google.android.material.button.MaterialButtonToggleGroup>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Paper Structure Card -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Studdy.Card.Flat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Paper Structure"
                                android:textColor="@color/text_primary"
                                android:textSize="16sp"
                                android:fontFamily="sans-serif-bold" />
                            <ImageView
                                android:id="@+id/btn_add_section_header"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_plus"
                                app:tint="@color/brand_primary"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:clickable="true"
                                android:focusable="true" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@color/brand_primary_surface"
                            android:padding="12dp"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Total Marks:"
                                android:textColor="@color/text_primary"
                                android:fontFamily="sans-serif-medium" />
                            <TextView
                                android:id="@+id/tv_total_marks"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 marks"
                                android:textColor="@color/brand_primary"
                                android:textSize="16sp"
                                android:fontFamily="sans-serif-bold" />
                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rv_sections"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            tools:listitem="@layout/item_paper_section" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_add_section"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="+ Add Section"
                            android:textAllCaps="false"
                            app:cornerRadius="12dp"
                            app:strokeColor="@color/brand_primary"
                            android:textColor="@color/brand_primary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- Bottom Action -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_card"
            android:padding="16dp"
            android:elevation="8dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_generate_with_ai"
                style="@style/Studdy.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Generate Paper"
                android:textAllCaps="false"
                app:cornerRadius="16dp"
                android:fontFamily="sans-serif-bold"
                android:backgroundTint="#9C27B0" />
        </LinearLayout>
    </LinearLayout>

    <!-- Centered Modal Loader Overlay -->
    <FrameLayout
        android:id="@+id/layout_loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Material3.CardView.Elevated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/bg_card">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="28dp">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/progress_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    app:indicatorColor="@color/brand_primary" />

                <TextView
                    android:id="@+id/tv_loading_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Processing..."
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
