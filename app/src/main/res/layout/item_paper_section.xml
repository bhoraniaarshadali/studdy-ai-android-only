<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#F8F9FE"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#EEF0F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <ImageView
            android:id="@+id/iv_section_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle_primary_light"
            android:padding="10dp"
            android:src="@drawable/ic_mcq_exam"
            app:tint="@color/brand_primary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_section_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Section A - MCQ"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-bold" />

            <TextView
                android:id="@+id/tv_section_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="10 questions × 1 marks = 10 marks"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tv_section_type_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pill_accent"
                    android:backgroundTint="#E3F2FD"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:text="MCQ"
                    android:textColor="#2196F3"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-bold" />

                <TextView
                    android:id="@+id/tv_section_diff_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_pill_accent"
                    android:backgroundTint="#F1F8E9"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:text="EASY"
                    android:textColor="#4CAF50"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-bold" />
            </LinearLayout>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_delete_section"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_delete"
            app:tint="#EF5350" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
