<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Question text card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Studdy.Card.Flat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tv_question_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingMultiplier="1.2"
                android:padding="20dp"
                android:textColor="@color/text_primary"
                android:textSize="17sp"
                tools:text="Which of the following is the fundamental unit of electric current in the International System of Units (SI)?" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Options Container -->
        <LinearLayout
            android:id="@+id/layout_options_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Option A -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_option_0"
                style="@style/Studdy.Card.Flat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                app:strokeColor="@color/stroke_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_option_label_0"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_circle_primary_light"
                        android:gravity="center"
                        android:textColor="@color/brand_primary"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:text="A" />

                    <TextView
                        android:id="@+id/tv_option_text_0"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        tools:text="Ampere" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Option B -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_option_1"
                style="@style/Studdy.Card.Flat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                app:strokeColor="@color/stroke_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_option_label_1"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_circle_primary_light"
                        android:gravity="center"
                        android:textColor="@color/brand_primary"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:text="B" />

                    <TextView
                        android:id="@+id/tv_option_text_1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        tools:text="Volt" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Option C -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_option_2"
                style="@style/Studdy.Card.Flat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                app:strokeColor="@color/stroke_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_option_label_2"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_circle_primary_light"
                        android:gravity="center"
                        android:textColor="@color/brand_primary"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:text="C" />

                    <TextView
                        android:id="@+id/tv_option_text_2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        tools:text="Ohm" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Option D -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_option_3"
                style="@style/Studdy.Card.Flat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                app:strokeColor="@color/stroke_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_option_label_3"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_circle_primary_light"
                        android:gravity="center"
                        android:textColor="@color/brand_primary"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:text="D" />

                    <TextView
                        android:id="@+id/tv_option_text_3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        tools:text="Coulomb" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
