<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!--  BASE THEME — Material3 DayNight, no action bar                    -->
    <!-- ════════════════════════════════════════════════════════════════════ -->
    <style name="Base.Theme.StuddyAppandroidonly" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Colour tokens -->
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorPrimaryContainer">@color/brand_primary_surface</item>
        <item name="colorOnPrimaryContainer">@color/brand_primary_darker</item>
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorOnSecondary">@color/text_on_secondary</item>
        <item name="colorSecondaryContainer">@color/brand_secondary_light</item>
        <item name="colorTertiary">@color/brand_accent</item>
        <item name="colorError">@color/color_error</item>
        <item name="colorErrorContainer">@color/color_error_light</item>
        <item name="android:colorBackground">@color/bg_page</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorOutline">@color/stroke_light</item>

        <!-- Typography -->
        <item name="android:fontFamily">sans-serif</item>
        <item name="fontFamily">sans-serif</item>

        <!-- Window -->
        <item name="android:windowBackground">@color/bg_page</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.StuddyAppandroidonly" parent="Base.Theme.StuddyAppandroidonly" />

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!--  TOOLBAR STYLES                                                     -->
    <!-- ════════════════════════════════════════════════════════════════════ -->
    <style name="Studdy.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/bg_card</item>
        <item name="titleTextColor">@color/text_primary</item>
        <item name="subtitleTextColor">@color/text_secondary</item>
        <item name="navigationIconTint">@color/text_primary</item>
        <item name="android:theme">@style/ThemeOverlay.Material3.ActionBar</item>
    </style>

    <style name="Studdy.Toolbar.Gradient">
        <item name="android:background">@color/brand_primary</item>
        <item name="titleTextColor">@color/white</item>
        <item name="subtitleTextColor">#CCFFFFFF</item>
        <item name="navigationIconTint">@color/white</item>
    </style>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!--  BUTTON STYLES                                                      -->
    <!-- ════════════════════════════════════════════════════════════════════ -->
    <style name="Studdy.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:minHeight">52dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="backgroundTint">@color/brand_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:paddingStart">28dp</item>
        <item name="android:paddingEnd">28dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="Studdy.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">52dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textSize">15sp</item>
        <item name="strokeColor">@color/brand_primary</item>
        <item name="android:textColor">@color/brand_primary</item>
        <item name="android:paddingStart">28dp</item>
        <item name="android:paddingEnd">28dp</item>
    </style>

    <style name="Studdy.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/brand_primary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="Studdy.Button.Danger" parent="Widget.Material3.Button">
        <item name="android:minHeight">52dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="backgroundTint">@color/color_error</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!--  TEXT FIELD STYLES                                                  -->
    <!-- ════════════════════════════════════════════════════════════════════ -->
    <style name="Studdy.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/stroke_light</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="hintTextColor">@color/brand_primary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!--  CARD STYLES                                                        -->
    <!-- ════════════════════════════════════════════════════════════════════ -->
    <style name="Studdy.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardElevation">3dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="contentPadding">0dp</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">0.5dp</item>
    </style>

    <style name="Studdy.Card.Flat" parent="Widget.Material3.CardView.Outlined">
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!--  CHIP STYLES                                                        -->
    <!-- ════════════════════════════════════════════════════════════════════ -->
    <style name="Studdy.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">8dp</item>
        <item name="android:textSize">12sp</item>
        <item name="chipMinHeight">32dp</item>
    </style>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!--  TEXT APPEARANCES                                                   -->
    <!-- ════════════════════════════════════════════════════════════════════ -->
    <style name="Studdy.TextAppearance.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">26sp</item>
    </style>

    <style name="Studdy.TextAppearance.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">20sp</item>
    </style>

    <style name="Studdy.TextAppearance.Subtitle" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="Studdy.TextAppearance.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="Studdy.TextAppearance.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="Studdy.TextAppearance.Label" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!--  DIALOG STYLE                                                       -->
    <!-- ════════════════════════════════════════════════════════════════════ -->
    <style name="Studdy.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="shapeAppearanceMediumComponent">@style/Studdy.Dialog.Shape</item>
    </style>

    <style name="Studdy.Dialog.Shape" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!--  TAB LAYOUT                                                         -->
    <!-- ════════════════════════════════════════════════════════════════════ -->
    <style name="Studdy.TabLayout" parent="Widget.Material3.TabLayout">
        <item name="tabIndicatorColor">@color/brand_primary</item>
        <item name="tabSelectedTextColor">@color/brand_primary</item>
        <item name="tabTextColor">@color/text_secondary</item>
        <item name="tabIndicatorHeight">3dp</item>
        <item name="tabTextAppearance">@style/Studdy.TabTextAppearance</item>
    </style>

    <style name="Studdy.TabTextAppearance" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="textAllCaps">false</item>
    </style>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!--  BOTTOM SHEET STYLE                                                  -->
    <!-- ════════════════════════════════════════════════════════════════════ -->
    <style name="Studdy.BottomSheetDialog" parent="Theme.Material3.DayNight.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Studdy.BottomSheet</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/white</item>
    </style>

    <style name="Studdy.BottomSheet" parent="Widget.Material3.BottomSheet">
        <item name="shapeAppearanceOverlay">@style/Studdy.BottomSheet.Shape</item>
        <item name="backgroundTint">@color/white</item>
    </style>

    <style name="Studdy.BottomSheet.Shape" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">32dp</item>
        <item name="cornerSizeTopRight">32dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

</resources>