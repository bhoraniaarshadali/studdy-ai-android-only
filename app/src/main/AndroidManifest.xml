<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ── Permissions ──────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CAMERA" />

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.camera.front"
        android:required="false" />

    <application
        android:name=".StuddyApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.StuddyAppandroidonly"
        android:usesCleartextTraffic="false">

        <!-- ── Launcher / Session Router ──────────────────────────────── -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ── Auth ───────────────────────────────────────────────────── -->
        <activity
            android:name=".ui.home.RoleSelectionActivity"
            android:exported="false" />

        <activity
            android:name=".ui.auth.TeacherAuthActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.auth.StudentAuthActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.auth.ResetPasswordActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter android:label="Reset Password">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="studdyapp" android:host="reset-password" />
            </intent-filter>
        </activity>

        <!-- ── Teacher ─────────────────────────────────────────────────── -->
        <activity
            android:name=".ui.teacher.dashboard.TeacherDashboardActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.teacher.create.CreateExamActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.teacher.create.PaperGeneratorActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.teacher.results.ExamResultsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.teacher.results.ExamAnswerKeyActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.teacher.monitor.ExamMonitorActivity"
            android:exported="false" />

        <activity
            android:name=".ui.teacher.papers.PaperListActivity"
            android:exported="false" />

        <activity
            android:name=".ui.teacher.papers.PaperDetailActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- ── Student ─────────────────────────────────────────────────── -->
        <activity
            android:name=".ui.student.entry.StudentEntryActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.student.dashboard.StudentDashboardActivity"
            android:exported="false" />

        <activity
            android:name=".ui.student.dashboard.MyResultsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.student.exam.ExamActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.student.exam.PreExamInstructionsActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.student.result.StudentResultActivity"
            android:exported="false" />

        <!-- ── QR ──────────────────────────────────────────────────────── -->
        <activity
            android:name=".ui.qr.QrScanActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.qr.QrDisplayActivity"
            android:exported="false" />

    </application>

</manifest>